# ── Branding ─────────────────────────────────────────
APP_NAME=AuthGate
APP_LOGO_URL=
APP_TAGLINE=Secure authentication for your apps
ACCENT_COLOR=#6366f1
# Default theme for the login page: "light", "dark", or "auto" (follows system preference)
# Client apps can override this per-request via ?theme=light or ?theme=dark
DEFAULT_THEME=light
# Path to a custom Jinja2 HTML template for the login page (optional)
# If empty, the built-in login.html is used
CUSTOM_LOGIN_TEMPLATE=

# ── Server ───────────────────────────────────────────
SECRET_KEY=generate-a-strong-random-string-here
ALLOWED_REDIRECTS=http://localhost:3000/*
CORS_ORIGINS=http://localhost:3000

# ── Database ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://authgate:authgate@postgres:5432/authgate

# ── JWT ──────────────────────────────────────────────
JWT_EXPIRY_HOURS=24
JWT_KEYS_DIR=./keys
COOKIE_NAME=authgate_token
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ── Providers ────────────────────────────────────────
# Comma-separated list of providers to enable: github,google,gitlab
# Leave empty to auto-detect from available credentials (local dev)
ENABLED_PROVIDERS=

# ── GitHub OAuth ─────────────────────────────────────
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Google OAuth ─────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── GitLab OAuth ─────────────────────────────────────
GITLAB_CLIENT_ID=
GITLAB_CLIENT_SECRET=
GITLAB_BASE_URL=https://gitlab.com
